# Infra (docker-compose)
COMPOSE_PROJECT_NAME=bandnine
API_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
POSTGRES_DB=bandnine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend runtime (CRA)
REACT_APP_HOST_API=http://localhost:8000
REACT_APP_ASSETS_API=
REACT_APP_MAPBOX_API=
REACT_APP_DEFAULT_API_LANG=uz
REACT_APP_AUTH_MOCK=false
REACT_APP_SPEAKING_USE_BACKEND_DECISIONS=true

# App
APP_NAME=bandnine
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CONFIRM_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bandnine
REDIS_URL=redis://redis:6379/0

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com

FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

RATE_LIMIT_SIGN_IN=10
RATE_LIMIT_RESET=5
RATE_LIMIT_WINDOW_SECONDS=60

EXPOSE_DEBUG_TOKENS=false

# Tests (SQLite only)
TEST_DATABASE_URL=sqlite+aiosqlite:///./backend/test.db
