# Compose
COMPOSE_PROJECT_NAME=bandnine-prod

# Public ports on server
# NOTE: TCP ports are valid only in range 1..65535, so 80000 cannot be used.
API_PORT=18000
FRONTEND_PORT=30000
LANDING_PORT=31000
POSTGRES_PORT=54320
REDIS_PORT=63790
# Caddy ports (used only if you run caddy route instead of host nginx)
CADDY_HTTP_PORT=800
CADDY_HTTPS_PORT=4430

# Frontend build-time vars
PROD_FRONTEND_API_ORIGIN=https://api.bandnine.online
PROD_FRONTEND_ASSETS_API=
PROD_FRONTEND_MAPBOX_API=
PROD_FRONTEND_DEFAULT_API_LANG=uz
PROD_FRONTEND_AUTH_MOCK=false
PROD_FRONTEND_SPEAKING_USE_BACKEND_DECISIONS=true

# Landing build-time vars
PROD_LANDING_PLATFORM_URL=https://ielts.bandnine.online

# App
APP_NAME=bandnine
ENVIRONMENT=production
DEBUG=false
API_PREFIX=/api/v1

SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CONFIRM_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=1

# Database / Cache
POSTGRES_DB=bandnine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bandnine
REDIS_URL=redis://redis:6379/0

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@bandnine.online

# CORS / Front
FRONTEND_BASE_URL=https://ielts.bandnine.online
CORS_ALLOW_ORIGINS=https://ielts.bandnine.online,https://bandnine.online
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Limits
RATE_LIMIT_SIGN_IN=10
RATE_LIMIT_RESET=5
RATE_LIMIT_WINDOW_SECONDS=60
EXPOSE_DEBUG_TOKENS=false
